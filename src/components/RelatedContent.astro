---
import { getCollection } from 'astro:content';

interface Props {
  relatedProjects?: string[];
  relatedDecisions?: string[];
  title?: string;
}

const {
  relatedProjects = [],
  relatedDecisions = [],
  title = '延伸阅读',
} = Astro.props;

const allProjects = await getCollection('projects');
const allDecisions = await getCollection('decisions');

const projects = relatedProjects
  .map((slug) => allProjects.find((project) => project.id === slug))
  .filter((project): project is NonNullable<typeof project> => project !== undefined);

const decisions = relatedDecisions
  .map((slug) => allDecisions.find((decision) => decision.id === slug))
  .filter((decision): decision is NonNullable<typeof decision> => decision !== undefined);

const hasRelated = projects.length > 0 || decisions.length > 0;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'short',
  }).format(date);
}
---

{hasRelated && (
  <aside class="related-content">
    <h2 class="related-title">{title}</h2>

    <div class="related-grid">
      {projects.length > 0 && (
        <section class="related-section">
          <h3 class="related-section-title">相关项目</h3>
          <ul class="related-list">
            {projects.map((project) => (
              <li>
                <a href={`/projects/${project.id}`} class="related-item">
                  <span class="related-item-meta">{project.data.role} · {project.data.year}</span>
                  <span class="related-item-title">{project.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {decisions.length > 0 && (
        <section class="related-section">
          <h3 class="related-section-title">相关判断</h3>
          <ul class="related-list">
            {decisions.map((decision) => (
              <li>
                <a href={`/decisions/${decision.id}`} class="related-item">
                  <span class="related-item-meta">{formatDate(decision.data.date)}</span>
                  <span class="related-item-title">{decision.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </aside>
)}

<style>
  .related-content {
    padding: 1.7rem 1.8rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-section-title {
    margin-bottom: 0.9rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .related-item {
    display: block;
    padding: 1rem 1.1rem;
    border: 2px solid var(--color-border);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .related-item:hover {
    transform: translateY(-2px);
    background: var(--color-tag-blue);
    color: var(--color-text);
  }

  .related-item-meta {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .related-item-title {
    display: block;
    font-size: 0.98rem;
    line-height: 1.5;
    font-weight: 700;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .related-content {
      padding: 1.25rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

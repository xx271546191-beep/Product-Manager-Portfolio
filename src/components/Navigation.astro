---
import { siteConfig } from '../config';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: '首页', href: '/' },
  ...siteConfig.nav,
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav class="site-nav" aria-label="主导航">
  <div class="nav-pill">
    <span class="nav-kicker">{siteConfig.author.name} · PM Portfolio</span>

    <div class="nav-scroll">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class="nav-item">
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  function updateActiveNav() {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link');

    navLinks.forEach((link) => {
      const href = link.getAttribute('href');
      let active = false;

      if (href === '/') {
        active = currentPath === '/';
      } else if (href) {
        active = currentPath.startsWith(href);
      }

      link.classList.toggle('nav-link--active', active);

      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  document.addEventListener('astro:page-load', updateActiveNav);
</script>

<style>
  .site-nav {
    max-width: 1180px;
    margin: 0 auto;
  }

  .nav-pill {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1rem;
    border: 2.5px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255, 250, 243, 0.92);
    box-shadow: 0 18px 32px rgba(102, 80, 52, 0.12), 4px 4px 0 var(--color-border);
    backdrop-filter: blur(10px);
  }

  .nav-kicker {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: var(--color-tag-yellow);
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nav-scroll {
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .nav-list {
    display: flex;
    justify-content: flex-end;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: max-content;
  }

  .nav-item {
    margin: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-tag-blue);
    transform: translateY(-1px);
  }

  .nav-link--active {
    color: var(--color-bg);
    background: var(--color-border);
  }

  .nav-link--active:hover {
    background: var(--color-border);
    color: var(--color-bg);
    transform: none;
  }

  @media (max-width: 760px) {
    .nav-pill {
      gap: 0.65rem;
      padding: 0.65rem 0.75rem;
    }

    .nav-kicker {
      display: none;
    }

    .nav-list {
      justify-content: flex-start;
      gap: 0.35rem;
    }

    .nav-link {
      padding: 0.65rem 0.9rem;
      font-size: 0.88rem;
    }
  }
</style>

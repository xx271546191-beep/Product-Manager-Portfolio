---
interface Props {
  href: string;
  text: string;
}

const { href, text } = Astro.props;
---

<div class="back-link-container">
  <a href={href} class="back-link">
    <svg class="back-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M9.70711 17.2929C10.0976 17.6834 10.0976 18.3166 9.70711 18.7071C9.31658 19.0976 8.68342 19.0976 8.29289 18.7071L2.29289 12.7071C1.90237 12.3166 1.90237 11.6834 2.29289 11.2929L8.29289 5.29289C8.68342 4.90237 9.31658 4.90237 9.70711 5.29289C10.0976 5.68342 10.0976 6.31658 9.70711 6.70711L5.41421 11L21 11C21.5523 11 22 11.4477 22 12C22 12.5523 21.5523 13 21 13L5.41422 13L9.70711 17.2929Z"/>
    </svg>
    {text}
  </a>
</div>

<style>
  .back-link-container {
    padding: 1.35rem 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-pill);
    background: rgba(255, 255, 255, 0.82);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .back-link:hover {
    transform: translateY(-2px);
    background: var(--color-tag-yellow);
    color: var(--color-text);
  }

  .back-icon {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .back-link:hover .back-icon {
    transform: translateX(-3px);
  }

  @media (max-width: 640px) {
    .back-link-container {
      padding: 1.25rem;
    }

    .back-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>

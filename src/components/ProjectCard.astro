---
import BaseCard from './BaseCard.astro';
import ForwardLink from './ForwardLink.astro';

interface Props {
  title: string;
  slug: string;
  outcomeSummary: string;
  role: string;
  year: number;
  techStack?: string[];
  featured?: boolean;
  status?: 'completed' | 'ongoing' | 'archived';
  signals?: string[];
  tone?: 'yellow' | 'blue' | 'pink' | 'green';
}

const {
  title,
  slug,
  outcomeSummary,
  role,
  year,
  techStack = [],
  featured = false,
  status = 'completed',
  signals = [],
  tone = 'yellow',
} = Astro.props;

const displayTech = techStack.slice(0, 4);

const statusConfig = {
  completed: { label: '已完成', class: 'status--completed' },
  ongoing: { label: '进行中', class: 'status--ongoing' },
  archived: { label: '已归档', class: 'status--archived' },
};

const statusInfo = statusConfig[status];
---

<BaseCard href={`/projects/${slug}`} class={`project-card project-card--${tone}`}>
  <div slot="badge" class="card-top">
    <div class="card-top__badges">
      {featured && <span class="featured-badge">重点项目</span>}
      <span class:list={['status-badge', statusInfo.class]}>{statusInfo.label}</span>
    </div>

    {signals.length > 0 && (
      <div class="card-top__signals">
        {signals.map((signal) => (
          <span class="signal-badge">{signal}</span>
        ))}
      </div>
    )}
  </div>

  <Fragment slot="meta">{role} · {year}</Fragment>
  <Fragment slot="title">{title}</Fragment>
  <Fragment slot="description">{outcomeSummary}</Fragment>

  {displayTech.length > 0 && (
    <div slot="tags" class="tags-list">
      {displayTech.map((tech) => (
        <span class="tag">{tech}</span>
      ))}
    </div>
  )}

  <ForwardLink text="查看项目案例" variant="muted" />
</BaseCard>

<style>
  .project-card {
    height: 100%;
    border-width: 2px;
    border-radius: 1.5rem;
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background-color var(--transition-fast);
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .project-card--yellow {
    background: linear-gradient(180deg, rgba(244, 213, 106, 0.22) 0%, var(--color-bg-elevated) 34%);
  }

  .project-card--blue {
    background: linear-gradient(180deg, rgba(188, 215, 255, 0.24) 0%, var(--color-bg-elevated) 34%);
  }

  .project-card--pink {
    background: linear-gradient(180deg, rgba(246, 191, 211, 0.24) 0%, var(--color-bg-elevated) 34%);
  }

  .project-card--green {
    background: linear-gradient(180deg, rgba(205, 235, 199, 0.24) 0%, var(--color-bg-elevated) 34%);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .card-top__badges,
  .card-top__signals,
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .featured-badge,
  .status-badge,
  .signal-badge,
  .tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 0.3rem 0.7rem;
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-pill);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .featured-badge {
    background: var(--color-tag-yellow);
  }

  .status-badge {
    background: rgba(255, 255, 255, 0.7);
  }

  .status--completed {
    background: var(--color-tag-green);
  }

  .status--ongoing {
    background: var(--color-tag-blue);
  }

  .status--archived {
    background: rgba(255, 255, 255, 0.7);
    color: var(--color-text-muted);
  }

  .signal-badge {
    background: rgba(255, 255, 255, 0.88);
  }

  .tag {
    background: rgba(255, 255, 255, 0.78);
    font-weight: 600;
  }

  .project-card :global(.card-meta) {
    margin-bottom: 0.7rem;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  .project-card :global(.card-title) {
    margin-bottom: 0.7rem;
    font-size: 1.45rem;
    line-height: 1.08;
    font-weight: 800;
  }

  .project-card :global(.card-description) {
    margin-bottom: 1rem;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .project-card :global(.arrow-link) {
    margin-top: 1.2rem;
    font-weight: 800;
  }

  @media (max-width: 640px) {
    .project-card :global(.card-title) {
      font-size: 1.2rem;
    }

    .project-card :global(.card-description) {
      font-size: 0.92rem;
    }
  }
</style>

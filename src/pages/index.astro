---
/**
 * 首页
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import { siteConfig } from '../config';
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <!-- Structured Data for Homepage -->
  <StructuredData type="WebSite" />
  <StructuredData type="Person" />

  <main class="home-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-left">
          <h1 class="hero-title">
            <span class="hero-label">AI产品经理实习生</span>
            {siteConfig.author.name}
          </h1>
          <p class="hero-sub">
            湖南农业大学硕士在读（2024—2027） · 企业知识库与行业智能化场景
          </p>
          <p class="hero-desc">
            面向企业知识库与行业智能化场景，具备从需求调研、PRD/原型设计、测试评估、Bad Case 收敛到方案交付支持的完整项目经验。
          </p>
          <div class="hero-cta">
            <a href="/projects" class="btn-primary">查看作品</a>
            <a href="/contact" class="btn-secondary">联系我</a>
          </div>
        </div>
        <div class="hero-right">
          <img src="/证件照.png" alt={siteConfig.author.name} class="profile-photo" />
        </div>
      </div>
    </section>

    <!-- Project Showcase with Images -->
    <section class="projects-showcase">
      <h2 class="section-title">项目作品</h2>
      
      <div class="project-grid">
        <div class="project-card">
          <div class="project-image">
            <img src="/筑云知识库首页.png" alt="筑云智库知识平台首页" class="project-img" />
          </div>
          <div class="project-info">
            <span class="project-role">AI产品经理（实习） · 2026</span>
            <h3 class="project-title">筑云智库知识平台</h3>
            <p class="project-desc">参与某省电信数据中心知识平台从 Demo 验证推进到立项评估，围绕引用溯源、图文回答与 PDF 预览定位等能力做设计与测试收敛。</p>
            <a href="/projects/zhuyun-knowledge-platform" class="project-link">了解更多 →</a>
          </div>
        </div>

        <div class="project-card">
          <div class="project-image">
            <div class="project-image-placeholder">某地石化电子操作票 AI 应用</div>
          </div>
          <div class="project-info">
            <span class="project-role">AI产品经理（实习） · 2026</span>
            <h3 class="project-title">某地石化电子操作票 AI 应用</h3>
            <p class="project-desc">基于既有系统做二期升级，访谈 6 个部门、梳理 33 项需求，独立完成可行性报告与系统原型，规划 AI 审核、唱票识别、DCS 联动与全流程风控机制。</p>
            <a href="/projects/local-operation-ticket-ai" class="project-link">了解更多 →</a>
          </div>
        </div>

        <div class="project-card">
          <div class="project-image">
            <div class="project-image-placeholder">RouteRAG / MyOCR</div>
          </div>
          <div class="project-info">
            <span class="project-role">个人预研项目 · 2026</span>
            <h3 class="project-title">RouteRAG</h3>
            <p class="project-desc">围绕复杂光缆路由图场景设计多模态 RAG Demo，完成 PRD、三层架构、固定 schema 与检索 / 抽取 / 展示链路设计，当前推进 MVP 骨架验证。</p>
            <a href="/projects/route-rag" class="project-link">了解更多 →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="skills-section">
      <h2 class="section-title">技能领域</h2>
      <div class="skills-grid">
        <div class="skill-item">
          <span class="skill-name">需求调研</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">PRD / 原型设计</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">RAG链路理解</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">测试评估</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">Bad Case收敛</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">方案汇报</span>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="experience-section">
      <h2 class="section-title">职业历程</h2>
      <div class="experience-timeline">
        <div class="experience-item">
          <span class="experience-year">2025.12—2026.03</span>
          <h3 class="experience-title">广州浩传科技 · AI产品经理（实习）</h3>
          <p class="experience-desc">参与电信、石化、煤矿、政务等 ToB / ToG 场景 AI 产品项目，覆盖需求调研、原型设计、测试推进、方案汇报与客户演示支持。</p>
        </div>
        <div class="experience-item">
          <span class="experience-year">2024—2027</span>
          <h3 class="experience-title">湖南农业大学 · 农学硕士在读</h3>
          <p class="experience-desc">预计 2027 年毕业，持续补齐产品经理、AI 应用与知识库/RAG 方向的实践能力。</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <h2>欢迎交流</h2>
      <p>如果你对 AI 产品、企业知识库、RAG 或行业智能化场景感兴趣，欢迎和我交流。</p>
      <div class="cta-buttons">
        <a href="/projects" class="btn-primary">查看我的作品</a>
        <a href="/contact" class="btn-secondary">联系我</a>
      </div>
    </section>
  </main>

  <style>
    .home-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 2rem;
      letter-spacing: -0.02em;
    }

    /* Hero Section */
    .hero {
      padding: 6rem 0 4rem;
      border-bottom: 2px solid var(--color-text);
      margin-bottom: 4rem;
    }

    .hero-content {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 4rem;
      align-items: center;
    }

    .hero-title {
      font-size: 4rem;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
    }

    .profile-photo {
      width: 250px;
      height: 300px;
      object-fit: cover;
      border: 2px solid var(--color-text);
    }

    .hero-label {
      display: block;
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-sub {
      font-size: 1.25rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    }

    .hero-desc {
      font-size: 1rem;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
      max-width: 500px;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
    }

    .btn-primary {
      display: inline-block;
      padding: 1rem 2rem;
      background: var(--color-text);
      color: var(--color-bg);
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    .btn-primary:hover {
      opacity: 0.8;
    }

    .btn-secondary {
      display: inline-block;
      padding: 1rem 2rem;
      background: transparent;
      color: var(--color-text);
      font-weight: 500;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid var(--color-text);
      transition: background 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
      background: var(--color-text);
      color: var(--color-bg);
    }

    /* Projects Showcase */
    .projects-showcase {
      margin-bottom: 5rem;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .project-card {
      border: 2px solid var(--color-text);
      overflow: hidden;
    }

    .project-image {
      aspect-ratio: 16/9;
      background: var(--color-bg-secondary);
      border-bottom: 2px solid var(--color-text);
      overflow: hidden;
    }

    .project-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .project-image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
      color: var(--color-text-muted);
      font-size: 1.25rem;
      font-weight: 500;
    }

    .project-info {
      padding: 1.5rem;
    }

    .project-role {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .project-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .project-desc {
      font-size: 1rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
      line-height: 1.6;
    }

    .project-link {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-text);
      text-decoration: none;
    }

    .project-link:hover {
      text-decoration: underline;
    }

    /* Skills Section */
    .skills-section {
      margin-bottom: 5rem;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .skill-item {
      padding: 1rem 1.5rem;
      border: 2px solid var(--color-text);
      text-align: center;
    }

    .skill-name {
      font-size: 1rem;
      font-weight: 600;
    }

    /* Experience Section */
    .experience-section {
      margin-bottom: 5rem;
    }

    .experience-timeline {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .experience-item {
      padding: 1.5rem;
      border-left: 4px solid var(--color-text);
      background: var(--color-bg-secondary);
    }

    .experience-year {
      display: block;
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .experience-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .experience-desc {
      font-size: 0.9375rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
    }

    /* CTA */
    .cta {
      padding: 3rem 0;
      border-top: 2px solid var(--color-text);
    }

    .cta h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }

    .cta p {
      font-size: 1rem;
      color: var(--color-text-secondary);
      margin-bottom: 1.5rem;
      max-width: 500px;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
    }

    @media (max-width: 768px) {
      .home-page {
        padding: 0 1rem 3rem;
      }

      .hero {
        padding: 3rem 0 2rem;
      }

      .hero-content {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .hero-title {
        font-size: 2.5rem;
      }

      .profile-photo {
        width: 200px;
        height: 240px;
        margin: 0 auto;
      }

      .section-title {
        font-size: 1.75rem;
      }

      .skills-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .hero-cta,
      .cta-buttons {
        flex-direction: column;
      }

      .btn-primary,
      .btn-secondary {
        text-align: center;
        width: 100%;
      }
    }
  </style>
</BaseLayout>

---
/**
 * 首页
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(project => project.data.featured === true)
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 2);

const caseSnapshots = featuredProjects.slice(0, 3);
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <!-- Structured Data for Homepage -->
  <StructuredData type="WebSite" />
  <StructuredData type="Person" />

  <main class="home-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="hero-label">产品经理（实习）</span>
          {siteConfig.author.name}
        </h1>
        <p class="hero-sub">
          湖南农大硕士 · 浩传科技实习经历
        </p>
        <p class="hero-desc">
          专注于AI知识库产品落地，擅长需求规划、产品交付与跨团队协作。
        </p>
        <div class="hero-cta">
          <a href="/projects" class="btn-primary">查看作品</a>
          <a href="/contact" class="btn-secondary">联系我</a>
        </div>
      </div>
    </section>

    <!-- Project Showcase with Images -->
    <section class="projects-showcase">
      <h2 class="section-title">项目作品</h2>
      
      <div class="project-grid">
        <div class="project-card">
          <div class="project-image">
            <div class="project-image-placeholder">
              <span>筑云智库知识平台</span>
            </div>
          </div>
          <div class="project-info">
            <span class="project-role">产品助理 · 2024</span>
            <h3 class="project-title">筑云智库知识平台</h3>
            <p class="project-desc">参与AI知识库产品从Demo到V1迭代，建立产品交付标准</p>
            <a href="/projects" class="project-link">了解更多 →</a>
          </div>
        </div>

        <div class="project-card">
          <div class="project-image">
            <div class="project-image-placeholder">
              <span>AI运维智脑首页</span>
            </div>
          </div>
          <div class="project-info">
            <span class="project-role">产品助理 · 2024</span>
            <h3 class="project-title">AI运维智脑首页</h3>
            <p class="project-desc">独立完成静态页面，把知识库、数字孪生、物联网感知等模块用一张图讲清楚</p>
            <a href="/projects" class="project-link">了解更多 →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="skills-section">
      <h2 class="section-title">技能领域</h2>
      <div class="skills-grid">
        <div class="skill-item">
          <span class="skill-name">需求分析</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">产品规划</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">原型设计</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">数据分析</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">跨团队协作</span>
        </div>
        <div class="skill-item">
          <span class="skill-name">AI产品落地</span>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="experience-section">
      <h2 class="section-title">职业历程</h2>
      <div class="experience-timeline">
        <div class="experience-item">
          <span class="experience-year">2024</span>
          <h3 class="experience-title">浩传科技 · 产品助理</h3>
          <p class="experience-desc">参与「筑云智库知识平台」从Demo到V1迭代，建立产品交付标准</p>
        </div>
        <div class="experience-item">
          <span class="experience-year">2022</span>
          <h3 class="experience-title">湖南农业大学 · 硕士</h3>
          <p class="experience-desc">非计算机专业，开始接触产品经理相关知识</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <h2>欢迎交流</h2>
      <p>如果你对产品设计、AI产品落地或产品经理职业发展感兴趣，欢迎一起交流探讨。</p>
      <div class="cta-buttons">
        <a href="/projects" class="btn-primary">查看我的作品</a>
        <a href="/contact" class="btn-secondary">联系我</a>
      </div>
    </section>
  </main>

  <style>
    .home-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 2rem;
      letter-spacing: -0.02em;
    }

    /* Hero Section */
    .hero {
      padding: 6rem 0 4rem;
      border-bottom: 2px solid var(--color-text);
      margin-bottom: 4rem;
    }

    .hero-title {
      font-size: 4rem;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
    }

    .hero-label {
      display: block;
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-sub {
      font-size: 1.25rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    }

    .hero-desc {
      font-size: 1rem;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
      max-width: 500px;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
    }

    .btn-primary {
      display: inline-block;
      padding: 1rem 2rem;
      background: var(--color-text);
      color: var(--color-bg);
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    .btn-primary:hover {
      opacity: 0.8;
    }

    .btn-secondary {
      display: inline-block;
      padding: 1rem 2rem;
      background: transparent;
      color: var(--color-text);
      font-weight: 500;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid var(--color-text);
      transition: background 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
      background: var(--color-text);
      color: var(--color-bg);
    }

    /* Projects Showcase */
    .projects-showcase {
      margin-bottom: 5rem;
    }

    .project-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .project-card {
      border: 2px solid var(--color-text);
      overflow: hidden;
    }

    .project-image {
      aspect-ratio: 16/9;
      background: var(--color-bg-secondary);
      border-bottom: 2px solid var(--color-text);
    }

    .project-image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
      color: var(--color-text-muted);
      font-size: 1.25rem;
      font-weight: 500;
    }

    .project-info {
      padding: 1.5rem;
    }

    .project-role {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .project-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .project-desc {
      font-size: 1rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
      line-height: 1.6;
    }

    .project-link {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-text);
      text-decoration: none;
    }

    .project-link:hover {
      text-decoration: underline;
    }

    /* Skills Section */
    .skills-section {
      margin-bottom: 5rem;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .skill-item {
      padding: 1rem 1.5rem;
      border: 2px solid var(--color-text);
      text-align: center;
    }

    .skill-name {
      font-size: 1rem;
      font-weight: 600;
    }

    /* Experience Section */
    .experience-section {
      margin-bottom: 5rem;
    }

    .experience-timeline {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .experience-item {
      padding: 1.5rem;
      border-left: 4px solid var(--color-text);
      background: var(--color-bg-secondary);
    }

    .experience-year {
      display: block;
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .experience-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .experience-desc {
      font-size: 0.9375rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
    }

    /* CTA */
    .cta {
      padding: 3rem 0;
      border-top: 2px solid var(--color-text);
    }

    .cta h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }

    .cta p {
      font-size: 1rem;
      color: var(--color-text-secondary);
      margin-bottom: 1.5rem;
      max-width: 500px;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
    }

    @media (max-width: 768px) {
      .home-page {
        padding: 0 1rem 3rem;
      }

      .hero {
        padding: 3rem 0 2rem;
      }

      .hero-title {
        font-size: 2.5rem;
      }

      .section-title {
        font-size: 1.75rem;
      }

      .skills-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .hero-cta,
      .cta-buttons {
        flex-direction: column;
      }

      .btn-primary,
      .btn-secondary {
        text-align: center;
        width: 100%;
      }
    }
  </style>
</BaseLayout>

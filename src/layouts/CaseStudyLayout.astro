---
import BaseLayout from './BaseLayout.astro';
---

<BaseLayout>
  <slot name="head" slot="head" />
  <div class="case-study-layout">
    <slot />
  </div>

  <style>
    .case-study-layout {
      max-width: 1040px;
      margin: 0 auto;
      padding: 2rem 1rem 4.5rem;
    }

    .case-study-layout :global(.case-study-shell) {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .case-study-layout :global(.case-study-header),
    .case-study-layout :global(.case-study-section),
    .case-study-layout :global(.case-study-content),
    .case-study-layout :global(.related-content),
    .case-study-layout :global(.back-link-container) {
      border: 2.5px solid var(--color-border);
      border-radius: 2rem;
      background: var(--color-bg-elevated);
      box-shadow: 6px 6px 0 var(--color-border), var(--shadow-md);
    }

    .case-study-layout :global(.case-study-header) {
      padding: 2rem;
      background:
        radial-gradient(circle at top right, rgba(188, 215, 255, 0.32), transparent 32%),
        radial-gradient(circle at 8% 18%, rgba(244, 213, 106, 0.34), transparent 22%),
        var(--color-bg-elevated);
    }

    .case-study-layout :global(.case-study-header__top) {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .case-study-layout :global(.case-study-eyebrow),
    .case-study-layout :global(.status-badge),
    .case-study-layout :global(.case-study-tech__tag),
    .case-study-layout :global(.case-study-action__kind) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0.35rem 0.8rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      font-size: 0.76rem;
      font-weight: 700;
      color: var(--color-text);
      line-height: 1;
    }

    .case-study-layout :global(.case-study-eyebrow) {
      background: var(--color-tag-yellow);
    }

    .case-study-layout :global(.status-badge) {
      background: rgba(255, 255, 255, 0.7);
    }

    .case-study-layout :global(.status--completed) {
      background: var(--color-tag-green);
    }

    .case-study-layout :global(.status--ongoing) {
      background: var(--color-tag-blue);
    }

    .case-study-layout :global(.status--archived) {
      color: var(--color-text-muted);
    }

    .case-study-layout :global(.case-study-header h1) {
      max-width: 13ch;
      margin-bottom: 0.9rem;
      font-size: clamp(2.4rem, 4.5vw, 4.2rem);
      line-height: 0.98;
      letter-spacing: -0.05em;
      font-weight: 800;
    }

    .case-study-layout :global(.case-study-meta) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-bottom: 1rem;
      color: var(--color-text-secondary);
      font-size: 0.95rem;
      font-weight: 600;
    }

    .case-study-layout :global(.meta-role) {
      color: var(--color-text);
      font-weight: 700;
    }

    .case-study-layout :global(.meta-separator) {
      color: var(--color-text-muted);
    }

    .case-study-layout :global(.outcome-summary) {
      max-width: 60ch;
      margin-bottom: 1.2rem;
      font-size: 1.06rem;
      line-height: 1.7;
      color: var(--color-text-secondary);
    }

    .case-study-layout :global(.case-study-tech) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-bottom: 1.2rem;
    }

    .case-study-layout :global(.case-study-tech__tag) {
      background: rgba(255, 255, 255, 0.82);
      font-weight: 600;
    }

    .case-study-layout :global(.case-study-actions),
    .case-study-layout :global(.case-study-content .prototype-links) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
    }

    .case-study-layout :global(.case-study-action),
    .case-study-layout :global(.case-study-content .prototype-link) {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      min-height: 48px;
      padding: 0.85rem 1.1rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      background: rgba(255, 255, 255, 0.82);
      color: var(--color-text);
      font-size: 0.94rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform var(--transition-fast), background-color var(--transition-fast);
    }

    .case-study-layout :global(.case-study-action:hover),
    .case-study-layout :global(.case-study-content .prototype-link:hover) {
      transform: translateY(-2px);
      background: var(--color-tag-yellow);
      color: var(--color-text);
    }

    .case-study-layout :global(.case-study-action__kind) {
      background: var(--color-tag-blue);
      font-size: 0.68rem;
    }

    .case-study-layout :global(.case-study-section) {
      padding: 1.7rem 1.8rem;
    }

    .case-study-layout :global(.case-study-section h2),
    .case-study-layout :global(.case-study-content h2),
    .case-study-layout :global(.related-title) {
      margin-bottom: 1rem;
      font-size: clamp(1.65rem, 2.8vw, 2.35rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      font-weight: 800;
    }

    .case-study-layout :global(.case-study-section p),
    .case-study-layout :global(.case-study-content p),
    .case-study-layout :global(.impact-qualitative) {
      color: var(--color-text-secondary);
      font-size: 1rem;
      line-height: 1.8;
    }

    .case-study-layout :global(.constraints-list),
    .case-study-layout :global(.tech-stack-list),
    .case-study-layout :global(.learnings-list),
    .case-study-layout :global(.case-study-content ul) {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .case-study-layout :global(.constraints-list li),
    .case-study-layout :global(.tech-stack-list li),
    .case-study-layout :global(.learnings-list li),
    .case-study-layout :global(.case-study-content li) {
      position: relative;
      padding: 0.55rem 0 0.55rem 1.5rem;
      color: var(--color-text-secondary);
      line-height: 1.75;
    }

    .case-study-layout :global(.constraints-list li::before),
    .case-study-layout :global(.tech-stack-list li::before),
    .case-study-layout :global(.learnings-list li::before),
    .case-study-layout :global(.case-study-content li::before) {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--color-accent);
      font-weight: 800;
    }

    .case-study-layout :global(.decisions-list) {
      display: grid;
      gap: 1rem;
    }

    .case-study-layout :global(.decision-item) {
      padding: 1.25rem;
      border: 2px solid var(--color-border);
      border-radius: 1.4rem;
      background: linear-gradient(180deg, rgba(244, 213, 106, 0.16) 0%, rgba(255, 255, 255, 0.85) 100%);
    }

    .case-study-layout :global(.decision-title) {
      margin-bottom: 0.85rem;
      font-size: 1.22rem;
      line-height: 1.3;
      font-weight: 800;
    }

    .case-study-layout :global(.decision-reasoning),
    .case-study-layout :global(.decision-alternatives) {
      margin-top: 0.9rem;
    }

    .case-study-layout :global(.decision-reasoning strong),
    .case-study-layout :global(.decision-alternatives strong) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.55rem;
      padding: 0.25rem 0.7rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      background: var(--color-tag-pink);
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--color-text);
    }

    .case-study-layout :global(.decision-reasoning p),
    .case-study-layout :global(.decision-alternatives li) {
      color: var(--color-text-secondary);
      font-size: 0.98rem;
      line-height: 1.75;
    }

    .case-study-layout :global(.decision-alternatives ul) {
      list-style: none;
      margin-top: 0.25rem;
      padding: 0;
    }

    .case-study-layout :global(.decision-alternatives li) {
      position: relative;
      padding-left: 1.3rem;
    }

    .case-study-layout :global(.decision-alternatives li::before) {
      content: "·";
      position: absolute;
      left: 0;
      color: var(--color-accent);
      font-size: 1.2rem;
      line-height: 1;
    }

    .case-study-layout :global(.case-study-content) {
      padding: 1.7rem 1.8rem;
    }

    .case-study-layout :global(.case-study-content h2) {
      margin-top: 0;
    }

    .case-study-layout :global(.case-study-content h3) {
      margin: 1.25rem 0 0.8rem;
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--color-text);
    }

    .case-study-layout :global(.case-study-content > * + *) {
      margin-top: 1rem;
    }

    @media (max-width: 820px) {
      .case-study-layout {
        padding: 1.2rem 0.75rem 3.5rem;
      }

      .case-study-layout :global(.case-study-header h1) {
        max-width: none;
      }
    }

    @media (max-width: 640px) {
      .case-study-layout :global(.case-study-header),
      .case-study-layout :global(.case-study-section),
      .case-study-layout :global(.case-study-content),
      .case-study-layout :global(.related-content),
      .case-study-layout :global(.back-link-container) {
        padding: 1.25rem;
        border-radius: 1.5rem;
        box-shadow: 4px 4px 0 var(--color-border), var(--shadow-sm);
      }

      .case-study-layout :global(.case-study-header__top) {
        flex-direction: column;
        align-items: flex-start;
      }

      .case-study-layout :global(.case-study-actions),
      .case-study-layout :global(.case-study-content .prototype-links) {
        flex-direction: column;
      }

      .case-study-layout :global(.case-study-action),
      .case-study-layout :global(.case-study-content .prototype-link) {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</BaseLayout>

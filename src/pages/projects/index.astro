---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { pagesConfig } from '../../pages.config';

const allProjects = await getCollection('projects');

const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  if (a.data.order !== undefined) return -1;
  if (b.data.order !== undefined) return 1;
  return b.data.year - a.data.year;
});

const totalProjects = sortedProjects.length;
const featuredCount = sortedProjects.filter((project) => project.data.featured).length;

const projectsWithDirectEntry = new Set([
  'route-rag',
  'local-operation-ticket-ai',
  'ai-handover-shift',
  'digital-human-ambassador',
]);

const signalMap: Record<string, string[]> = {
  'route-rag': ['附 GitHub 仓库'],
  'local-operation-ticket-ai': ['附静态原型'],
  'ai-handover-shift': ['附 PC / App 原型'],
  'digital-human-ambassador': ['附外部展示'],
};

const toneCycle = ['yellow', 'blue', 'pink', 'green'] as const;
const showcaseCount = sortedProjects.filter((project) => projectsWithDirectEntry.has(project.id)).length;
const directionCount = new Set(
  sortedProjects.flatMap((project) => project.data.techStack.slice(0, 2))
).size;

const heroStats = [
  { label: '项目案例', value: `${totalProjects}+`, tone: 'yellow' },
  { label: '重点项目', value: `${featuredCount}`, tone: 'blue' },
  { label: '可直达作品', value: `${showcaseCount}`, tone: 'pink' },
  { label: '能力方向', value: `${directionCount}+`, tone: 'green' },
];

const directionTags = ['知识库 / RAG', '工业流程升级', '数字人内容方案', '具身智能', '政务场景'];
---

<BaseLayout>
  <SEO
    slot="head"
    title={pagesConfig.projects.title}
    description={pagesConfig.projects.description}
    type="website"
  />

  <main class="projects-page">
    <section class="projects-hero">
      <div class="projects-hero__copy">
        <span class="section-pill">项目目录</span>
        <h1 class="projects-hero__title">把做过的项目拆成可以快速读懂的案例</h1>
        <p class="projects-hero__intro">
          这里收录的是我参与或主导过的项目作品。每个案例都会尽量讲清楚问题背景、关键判断、
          方案路径和最终价值，而不只停留在一句结果总结。
        </p>

        <div class="projects-hero__meta">
          <span class="hero-note">重点覆盖企业知识库、RAG、工业流程升级、数字人和具身智能场景</span>
        </div>

        <ul class="projects-hero__tags" aria-label="项目方向">
          {directionTags.map((tag, index) => (
            <li class:list={['projects-tag', `projects-tag--${index % 4}`]}>{tag}</li>
          ))}
        </ul>
      </div>

      <div class="projects-hero__stats" aria-label="项目统计">
        {heroStats.map((item) => (
          <article class:list={['hero-stat', `hero-stat--${item.tone}`]}>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </section>

    {sortedProjects.length > 0 ? (
      <section class="projects-listing">
        <div class="section-head">
          <span class="section-pill section-pill--blue">案例列表</span>
          <h2 class="section-title">按真实项目去看我如何做需求、做方案和推进落地</h2>
          <p class="section-intro">
            有原型、外链或 GitHub 仓库的项目，会在卡片里直接标出来，方便你先挑最感兴趣的看。
          </p>
        </div>

        <div class="projects-grid">
          {sortedProjects.map((project, index) => (
            <ProjectCard
              title={project.data.title}
              slug={project.id}
              outcomeSummary={project.data.outcomeSummary}
              role={project.data.role}
              year={project.data.year}
              techStack={project.data.techStack}
              featured={project.data.featured}
              status={project.data.status}
              signals={signalMap[project.id] ?? []}
              tone={toneCycle[index % toneCycle.length]}
            />
          ))}
        </div>
      </section>
    ) : (
      <p class="empty-state">项目内容还在整理中。</p>
    )}
  </main>
</BaseLayout>

<style>
  .projects-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem 4.5rem;
  }

  .projects-hero,
  .projects-listing,
  .empty-state {
    border: 2.5px solid var(--color-border);
    border-radius: 2rem;
    background: var(--color-bg-elevated);
    box-shadow: 6px 6px 0 var(--color-border), var(--shadow-md);
  }

  .projects-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding: 2rem;
  }

  .section-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    padding: 0.45rem 0.9rem;
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-pill);
    background: var(--color-tag-yellow);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .section-pill--blue {
    background: var(--color-tag-blue);
  }

  .projects-hero__title,
  .section-title {
    max-width: 12ch;
    font-size: clamp(2.2rem, 4.1vw, 3.8rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    font-weight: 800;
  }

  .projects-hero__intro,
  .section-intro {
    max-width: 60ch;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 1rem;
  }

  .projects-hero__meta {
    margin-top: 1.25rem;
  }

  .hero-note {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.7);
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .projects-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    margin-top: 1.25rem;
    padding: 0;
  }

  .projects-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.85rem;
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius-pill);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .projects-tag--0 {
    background: var(--color-tag-yellow);
  }

  .projects-tag--1 {
    background: var(--color-tag-blue);
  }

  .projects-tag--2 {
    background: var(--color-tag-pink);
  }

  .projects-tag--3 {
    background: var(--color-tag-green);
  }

  .projects-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-content: start;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 150px;
    padding: 1.1rem;
    border: 2px solid var(--color-border);
    border-radius: 1.4rem;
    box-shadow: var(--shadow-sm);
  }

  .hero-stat strong {
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1;
    font-weight: 800;
  }

  .hero-stat span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-secondary);
  }

  .hero-stat--yellow {
    background: var(--color-tag-yellow);
  }

  .hero-stat--blue {
    background: var(--color-tag-blue);
  }

  .hero-stat--pink {
    background: var(--color-tag-pink);
  }

  .hero-stat--green {
    background: var(--color-tag-green);
  }

  .projects-listing {
    padding: 1.8rem;
  }

  .section-head {
    margin-bottom: 1.4rem;
  }

  .section-title {
    max-width: 14ch;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty-state {
    padding: 2rem;
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .projects-hero,
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .projects-page {
      padding: 1.2rem 0.75rem 3.5rem;
    }

    .projects-hero {
      grid-template-columns: 1fr;
    }

    .projects-hero__title,
    .section-title {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .projects-hero,
    .projects-listing,
    .empty-state {
      padding: 1.25rem;
      border-radius: 1.5rem;
      box-shadow: 4px 4px 0 var(--color-border), var(--shadow-sm);
    }

    .projects-grid,
    .projects-hero__stats {
      grid-template-columns: 1fr;
    }

    .hero-stat {
      min-height: 112px;
    }

    .projects-hero__intro,
    .section-intro {
      font-size: 0.94rem;
    }
  }
</style>

---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import SEO from '../../components/SEO.astro';
import StructuredData from '../../components/StructuredData.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import BackLink from '../../components/BackLink.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import ImpactMetrics from '../../components/ImpactMetrics.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { calculateReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
  }));
}

const { slug } = Astro.params;
const project = await getEntry('projects', slug!);

if (!project) {
  return Astro.redirect('/404');
}

const { Content } = await render(project);

const {
  title,
  role,
  year,
  duration,
  teamSize,
  outcomeSummary,
  overview,
  problem,
  constraints,
  approach,
  keyDecisions,
  techStack,
  impact,
  learnings,
  relatedProjects,
  relatedDecisions,
  status,
} = project.data;

const statusConfig = {
  completed: { label: '已完成', class: 'status--completed' },
  ongoing: { label: '进行中', class: 'status--ongoing' },
  archived: { label: '已归档', class: 'status--archived' },
};

const statusInfo = statusConfig[status || 'completed'];

const allText = [
  overview,
  problem,
  approach,
  ...constraints,
  ...keyDecisions.map((decision) => `${decision.decision} ${decision.reasoning} ${decision.alternatives?.join(' ') || ''}`),
  impact.qualitative,
  ...learnings,
  project.body || '',
].join(' ');

const readingMinutes = calculateReadingTime(allText);

function stripHtmlTags(value: string) {
  return value.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
}

function inferActionKind(href: string, text: string) {
  const loweredHref = href.toLowerCase();
  const loweredText = text.toLowerCase();

  if (loweredHref.includes('github.com')) return '仓库';
  if (loweredHref.includes('/prototypes/') || loweredText.includes('原型')) return '原型';
  return '外部展示';
}

function extractActionLinks(body: string) {
  const matches = [...body.matchAll(/<a\s+class="prototype-link"\s+href="([^"]+)"[^>]*>([\s\S]*?)<\/a>/g)];

  return matches.slice(0, 3).map((match) => {
    const href = match[1];
    const text = stripHtmlTags(match[2]);

    return {
      href,
      text,
      kind: inferActionKind(href, text),
      external: href.startsWith('http'),
    };
  });
}

const actionLinks = extractActionLinks(project.body || '');
const metaItems = [
  `${year} 年`,
  duration,
  teamSize ? `${teamSize} 人协作` : undefined,
  `约 ${readingMinutes} 分钟阅读`,
].filter(Boolean);
---

<CaseStudyLayout>
  <SEO
    slot="head"
    title={`${title} - 项目案例`}
    description={outcomeSummary}
    type="article"
  />

  <StructuredData
    type="Project"
    data={{
      title,
      outcomeSummary,
      problem,
      impact: impact.qualitative,
      techStack,
      year,
    }}
  />

  <main class="case-study case-study-shell">
    <header class="case-study-header">
      <div class="case-study-header__top">
        <span class="case-study-eyebrow">项目案例</span>
        <div class="header-badges">
          <span class:list={['status-badge', statusInfo.class]}>{statusInfo.label}</span>
        </div>
      </div>

      <h1>{title}</h1>

      <div class="case-study-meta">
        <span class="meta-role">{role}</span>
        {metaItems.map((item) => (
          <>
            <span class="meta-separator">·</span>
            <span>{item}</span>
          </>
        ))}
      </div>

      <p class="outcome-summary">{outcomeSummary}</p>

      <div class="case-study-tech">
        {techStack.map((tech) => (
          <span class="case-study-tech__tag">{tech}</span>
        ))}
      </div>

      {actionLinks.length > 0 && (
        <div class="case-study-actions">
          {actionLinks.map((link) => (
            <a
              href={link.href}
              class="case-study-action"
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              <span class="case-study-action__kind">{link.kind}</span>
              <span>{link.text}</span>
            </a>
          ))}
        </div>
      )}
    </header>

    <section class="case-study-section">
      <h2>项目概述</h2>
      <p>{overview}</p>
    </section>

    <section class="case-study-section">
      <h2>核心问题</h2>
      <p>{problem}</p>
    </section>

    <section class="case-study-section">
      <h2>项目约束</h2>
      <ul class="constraints-list">
        {constraints.map((constraint) => (
          <li>{constraint}</li>
        ))}
      </ul>
    </section>

    <section class="case-study-section">
      <h2>方案路径</h2>
      <p>{approach}</p>
    </section>

    <section class="case-study-section">
      <h2>关键判断</h2>
      <div class="decisions-list">
        {keyDecisions.map((decision) => (
          <article class="decision-item">
            <h3 class="decision-title">{decision.decision}</h3>

            <div class="decision-reasoning">
              <strong>为什么这样做</strong>
              <p>{decision.reasoning}</p>
            </div>

            {decision.alternatives && decision.alternatives.length > 0 && (
              <div class="decision-alternatives">
                <strong>备选方案</strong>
                <ul>
                  {decision.alternatives.map((alt) => (
                    <li>{alt}</li>
                  ))}
                </ul>
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="case-study-section">
      <h2>关键能力 / 技术要点</h2>
      <ul class="tech-stack-list">
        {techStack.map((tech) => (
          <li>{tech}</li>
        ))}
      </ul>
    </section>

    <section class="case-study-section">
      <h2>结果与价值</h2>

      {impact.metrics && impact.metrics.length > 0 && (
        <ImpactMetrics metrics={impact.metrics} />
      )}

      <p class="impact-qualitative">{impact.qualitative}</p>
    </section>

    <section class="case-study-section">
      <h2>项目收获</h2>
      <ul class="learnings-list">
        {learnings.map((learning) => (
          <li>{learning}</li>
        ))}
      </ul>
    </section>

    {Content && (
      <section class="case-study-content">
        <Content />
      </section>
    )}

    <RelatedContent
      title="相关项目"
      relatedProjects={relatedProjects}
      relatedDecisions={relatedDecisions}
    />

    <BackLink href="/projects" text="返回项目列表" />
  </main>

  <ScrollToTop />
</CaseStudyLayout>

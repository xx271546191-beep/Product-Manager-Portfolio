---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import { siteConfig } from '../config';

const heroTags = ['需求调研', 'PRD / 原型', '测试评估', '知识库 / RAG', '方案汇报'];

const workShowcaseLinks = [
  {
    title: '交接班 PC 原型',
    description: '查看某地石化 AI 交接班管理系统 Web 端完整静态原型。',
    href: '/prototypes/handover-pc.html',
    external: true,
    tone: 'yellow',
  },
  {
    title: '交接班 App 原型',
    description: '查看现场侧交接发起、录音、摘要与待办执行的移动端原型。',
    href: '/prototypes/handover-app.html',
    external: true,
    tone: 'blue',
  },
  {
    title: '操作票原型',
    description: '查看某地石化电子操作票 AI 应用完整静态原型界面。',
    href: '/prototypes/operation-ticket.html',
    external: true,
    tone: 'pink',
  },
  {
    title: '数字人宁姐姐',
    description: '通过外部链接查看数字人项目展示内容，作为补充作品入口保留。',
    href: 'https://mp.weixin.qq.com/s/sAfaX1VON2dmfuac5gsDmQ',
    external: true,
    tone: 'green',
  },
  {
    title: 'RouteRAG GitHub',
    description: '查看 RouteRAG 当前公开仓库 `MyOCR`，了解项目代码与迭代方向。',
    href: 'https://github.com/xx271546191-beep/MyOCR',
    external: true,
    tone: 'yellow',
  },
];

const featuredProjects = [
  {
    title: '筑云智库知识平台',
    role: 'AI产品经理（实习）',
    year: '2026',
    href: '/projects/zhuyun-knowledge-platform',
    summary: '参与某省电信数据中心知识平台从 Demo 验证推进到立项评估，围绕引用溯源、图文回答与 PDF 预览定位做设计与测试收敛。',
    impact: '把“能不能做”推进到“值不值得立项”。',
    kicker: '知识库 / RAG',
    tone: 'blue',
    image: '/筑云知识库首页.png',
    imageAlt: '筑云智库知识平台首页',
  },
  {
    title: '某地石化电子操作票 AI 应用',
    role: 'AI产品经理（实习）',
    year: '2026',
    href: '/projects/local-operation-ticket-ai',
    summary: '围绕既有系统做二期升级，访谈 6 个部门、梳理 33 项需求，独立完成可行性报告与系统原型。',
    impact: '把 AI 审核、唱票识别、DCS 联动和全流程风控串成可落地方案。',
    kicker: '工业流程升级',
    tone: 'yellow',
  },
  {
    title: 'RouteRAG',
    role: '个人预研项目',
    year: '2026',
    href: '/projects/route-rag',
    summary: '围绕复杂光缆路由图场景设计多模态 RAG Demo，完成 PRD、三层架构、固定 schema 与检索 / 抽取 / 展示链路设计。',
    impact: '当前推进 MVP 骨架验证，聚焦“复杂资料如何被稳定读懂”。',
    kicker: '多模态预研',
    tone: 'pink',
  },
];

const workModes = [
  {
    title: '需求拆解',
    description: '先把业务场景、用户角色和约束条件拆清，再决定产品要解决的真问题。',
    tone: 'yellow',
  },
  {
    title: '产品规划',
    description: '把需求转成 PRD、原型、模块边界和迭代优先级，避免方案只停留在概念层。',
    tone: 'blue',
  },
  {
    title: '跨团队推进',
    description: '能在客户、研发、测试和内部汇报之间切换表达方式，把项目往前推。',
    tone: 'pink',
  },
  {
    title: 'AI 应用落地',
    description: '关注知识库、RAG、智能体与行业场景结合后的真正交付路径，而不是只讲模型能力。',
    tone: 'green',
  },
];

const timeline = [
  {
    period: '2025.12 — 2026.03',
    title: '广州浩传科技 · AI产品经理（实习）',
    description: '参与电信、石化、煤矿、政务等 ToB & ToG 场景 AI 产品项目，覆盖需求调研、原型设计、测试推进、方案汇报与客户演示支持。',
  },
  {
    period: '2024 — 2027',
    title: '湖南农业大学 · 农学硕士在读',
    description: '预计 2027 年毕业，持续补齐产品经理、AI 应用与知识库 / RAG 方向的实践能力。',
  },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <StructuredData type="WebSite" />
  <StructuredData type="Person" />

  <main class="home-page">
    <section class="hero">
      <div class="hero-copy">
        <div class="hero-badges" aria-label="身份标签">
          <span class="badge badge--blue">AI 产品经理</span>
          <span class="badge badge--yellow">求职作品集</span>
          <span class="badge badge--pink">知识库 / RAG</span>
        </div>

        <p class="hero-kicker">你好，我是 {siteConfig.author.name}</p>
        <h1 class="hero-title">
          <span class="hero-title__line">
            把 <span class="hero-highlight hero-highlight--yellow">AI 能力</span> 变成
          </span>
          <span class="hero-title__line">
            能落地的 <span class="hero-highlight hero-highlight--yellow">产品方案</span>
          </span>
        </h1>
        <p class="hero-summary">
          湖南农业大学硕士在读（2024—2027），聚焦企业知识库、RAG 与行业智能化场景，
          具备从需求调研、PRD / 原型设计，到测试评估、Bad Case 收敛和方案交付支持的完整项目经验。
        </p>

        <div class="hero-actions">
          <a href="/projects" class="button button--primary">查看项目</a>
          <a href="/contact" class="button button--secondary">联系我</a>
        </div>

        <ul class="hero-tags" aria-label="能力关键词">
          {heroTags.map((tag, index) => (
            <li class:list={['hero-tag', `hero-tag--${index % 3}`]}>{tag}</li>
          ))}
        </ul>
      </div>

      <div class="hero-visual">
        <div class="identity-card">
          <span class="identity-sticker identity-sticker--pink">求职中</span>
          <span class="identity-sticker identity-sticker--blue">Portfolio</span>

          <div class="illustration">
            <div class="illustration-orb illustration-orb--yellow"></div>
            <div class="illustration-orb illustration-orb--blue"></div>
            <div class="illustration-orb illustration-orb--pink"></div>
            <div class="photo-frame">
              <img src="/个人照片.png" alt={`${siteConfig.author.name}个人照片`} class="profile-photo" />
            </div>
          </div>

          <div class="identity-meta">
            <p class="identity-meta__title">AI 产品落地 / RAG / ToB &amp; ToG</p>
            <p class="identity-meta__text">
              用产品语言把复杂能力讲清楚，也把复杂流程拆到能落地。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="section-head">
        <span class="section-pill">项目作品直达</span>
        <h2 class="section-title">把最能体现能力的作品入口放在这里</h2>
      </div>

      <div class="works-grid">
        {workShowcaseLinks.map((item) => (
          <article class:list={['work-card', `work-card--${item.tone}`]}>
            <h3 class="work-card__title">{item.title}</h3>
            <p class="work-card__description">{item.description}</p>
            <a
              href={item.href}
              class="work-card__link"
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
            >
              立即查看
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="section-head section-head--center">
        <span class="section-pill">先看项目</span>
        <h2 class="section-title section-title--center">先看 3 个最能说明我能力的项目</h2>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => (
          <article class:list={['project-card', `project-card--${project.tone}`]}>
            <div class="project-card__media">
              {project.image ? (
                <img src={project.image} alt={project.imageAlt} class="project-card__image" />
              ) : (
                <div class="project-card__placeholder">
                  <span>{project.kicker}</span>
                  <strong>{project.title}</strong>
                </div>
              )}
            </div>

            <div class="project-card__body">
              <div class="project-card__meta">
                <span>{project.role}</span>
                <span>{project.year}</span>
              </div>
              <h3 class="project-card__title">{project.title}</h3>
              <p class="project-card__summary">{project.summary}</p>
              <p class="project-card__impact">{project.impact}</p>
              <a href={project.href} class="project-card__link">查看项目详情</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block section-block--split">
      <div class="section-head">
        <span class="section-pill">工作方式</span>
        <h2 class="section-title">我更像一个会把复杂问题讲清楚并推进下去的产品同学</h2>
      </div>

      <div class="workflow-grid">
        {workModes.map((mode) => (
          <article class:list={['workflow-card', `workflow-card--${mode.tone}`]}>
            <h3 class="workflow-card__title">{mode.title}</h3>
            <p class="workflow-card__description">{mode.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block section-block--narrow">
      <div class="section-head">
        <span class="section-pill">职业历程</span>
        <h2 class="section-title">目前的学习与实践轨迹</h2>
      </div>

      <div class="timeline">
        {timeline.map((item, index) => (
          <article class="timeline-item">
            <span class="timeline-marker">{index + 1}</span>
            <div class="timeline-item__content">
              <p class="timeline-period">{item.period}</p>
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-description">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-panel">
      <div>
        <span class="section-pill">继续浏览</span>
        <h2 class="section-title section-title--compact">如果你想继续了解我，下一步直接看项目或联系我。</h2>
      </div>

      <div class="cta-panel__actions">
        <a href="/projects" class="button button--primary">去看全部项目</a>
        <a href="/contact" class="button button--secondary">发起联系</a>
      </div>
    </section>
  </main>

  <style>
    .home-page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 2rem 1rem 4.5rem;
    }

    .hero,
    .section-block,
    .cta-panel {
      margin-bottom: 2rem;
      border: 2.5px solid var(--color-border);
      border-radius: 2rem;
      background: var(--color-bg-elevated);
      box-shadow: 6px 6px 0 var(--color-border), var(--shadow-md);
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
      gap: 2rem;
      padding: 2rem;
    }

    .hero-copy {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-badges,
    .hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .badge,
    .section-pill,
    .hero-tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.45rem 0.9rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--color-text);
    }

    .badge--blue,
    .hero-tag--1,
    .work-card--blue,
    .project-card--blue .project-card__placeholder,
    .workflow-card--blue {
      background: var(--color-tag-blue);
    }

    .badge--yellow,
    .hero-tag--0,
    .work-card--yellow,
    .project-card--yellow .project-card__placeholder,
    .workflow-card--yellow {
      background: var(--color-tag-yellow);
    }

    .badge--pink,
    .hero-tag--2,
    .work-card--pink,
    .project-card--pink .project-card__placeholder,
    .workflow-card--pink {
      background: var(--color-tag-pink);
    }

    .work-card--green,
    .workflow-card--green {
      background: var(--color-tag-green);
    }

    .section-pill {
      background: var(--color-tag-yellow);
      margin-bottom: 1rem;
    }

    .hero-kicker {
      margin-top: 1.25rem;
      margin-bottom: 0.8rem;
      font-size: clamp(1.5rem, 2vw, 2rem);
      line-height: 1.08;
      font-weight: 800;
      color: var(--color-text-secondary);
    }

    .hero-title {
      max-width: 11.5ch;
      font-size: clamp(2.45rem, 4.7vw, 4.35rem);
      line-height: 0.98;
      letter-spacing: -0.05em;
      font-weight: 800;
      margin-bottom: 1.2rem;
    }

    .hero-title__line {
      display: block;
      white-space: nowrap;
    }

    .hero-highlight {
      display: inline-block;
      margin: 0 0.15em;
      padding: 0.05em 0.18em;
      border-radius: 0.35em;
      box-shadow: inset 0 -0.45em 0 rgba(0, 0, 0, 0.03);
    }

    .hero-highlight--yellow {
      background: var(--color-tag-yellow);
    }

    .hero-summary {
      max-width: 58ch;
      margin-bottom: 1.6rem;
      font-size: 1.05rem;
      color: var(--color-text-secondary);
    }

    .hero-actions,
    .cta-panel__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0.9rem 1.35rem;
      border: 2.5px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      font-weight: 700;
      text-decoration: none;
      transition: transform var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
    }

    .button:hover {
      transform: translateY(-2px);
    }

    .button--primary {
      background: var(--color-border);
      color: var(--color-bg);
    }

    .button--primary:hover {
      color: var(--color-bg);
      background: #342d27;
    }

    .button--secondary {
      background: transparent;
      color: var(--color-text);
    }

    .button--secondary:hover {
      background: var(--color-tag-blue);
      color: var(--color-text);
    }

    .hero-tags {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      grid-auto-rows: 1fr;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .hero-tag {
      width: 100%;
      min-height: 52px;
      padding: 0.45rem 0.65rem;
      font-size: 0.78rem;
      line-height: 1;
      white-space: nowrap;
    }

    .hero-visual {
      display: flex;
      align-items: stretch;
      justify-content: center;
    }

    .identity-card {
      position: relative;
      width: 100%;
      min-height: 460px;
      padding: 1.25rem;
      border: 2.5px solid var(--color-border);
      border-radius: 1.8rem;
      background: linear-gradient(180deg, #fffdf7 0%, #fff1de 100%);
      overflow: hidden;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.7);
    }

    .identity-sticker {
      position: absolute;
      top: 1rem;
      padding: 0.45rem 0.8rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      font-size: 0.78rem;
      font-weight: 700;
      z-index: 2;
    }

    .identity-sticker--pink {
      left: 1rem;
      background: var(--color-tag-pink);
      transform: rotate(-5deg);
    }

    .identity-sticker--blue {
      right: 1rem;
      background: var(--color-tag-blue);
      transform: rotate(6deg);
    }

    .illustration {
      position: relative;
      height: 310px;
      margin-top: 2.2rem;
      border: 2px solid var(--color-border);
      border-radius: 1.4rem;
      background: rgba(255, 255, 255, 0.65);
      overflow: hidden;
    }

    .illustration-orb {
      position: absolute;
      border-radius: 999px;
      opacity: 0.95;
    }

    .illustration-orb--yellow {
      width: 190px;
      height: 190px;
      top: 32px;
      left: 28px;
      background: var(--color-tag-yellow);
    }

    .illustration-orb--blue {
      width: 160px;
      height: 160px;
      top: 46px;
      right: 24px;
      background: var(--color-tag-blue);
    }

    .illustration-orb--pink {
      width: 120px;
      height: 120px;
      bottom: 36px;
      left: 126px;
      background: var(--color-tag-pink);
    }

    .photo-frame {
      position: absolute;
      inset: 22px 18px 18px;
      border: 2px solid var(--color-border);
      border-radius: 1.2rem;
      background: rgba(255, 250, 243, 0.88);
      overflow: hidden;
      z-index: 1;
    }

    .profile-photo {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center top;
      background: #fff7ef;
    }

    .section-head--center {
      text-align: center;
    }

    .section-title--center {
      max-width: 13ch;
      margin-left: auto;
      margin-right: auto;
    }

    .section-head--center .section-pill {
      margin-left: auto;
      margin-right: auto;
    }

    .identity-meta {
      padding: 1.2rem 0.3rem 0.1rem;
    }

    .identity-meta__title {
      margin-bottom: 0.5rem;
      font-size: 1rem;
      font-weight: 800;
    }

    .identity-meta__text {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
    }

    .section-block {
      padding: 1.8rem;
    }

    .section-block--split,
    .section-block--narrow {
      background: rgba(255, 253, 248, 0.95);
    }

    .section-head {
      margin-bottom: 1.5rem;
    }

    .section-title {
      max-width: 18ch;
      font-size: clamp(2rem, 3.4vw, 3.2rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
      font-weight: 800;
    }

    .section-title--compact {
      max-width: 13ch;
    }

    .works-grid,
    .workflow-grid {
      display: grid;
      gap: 1rem;
    }

    .works-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .workflow-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .work-card,
    .workflow-card,
    .timeline-item {
      border: 2px solid var(--color-border);
      border-radius: 1.35rem;
      padding: 1.2rem;
      box-shadow: var(--shadow-sm);
    }

    .work-card {
      display: flex;
      flex-direction: column;
      min-height: 220px;
    }

    .work-card__title,
    .workflow-card__title,
    .timeline-title {
      margin-bottom: 0.55rem;
      font-size: 1.02rem;
      font-weight: 800;
    }

    .work-card__description,
    .workflow-card__description,
    .timeline-description {
      color: var(--color-text-secondary);
      font-size: 0.95rem;
    }

    .work-card__description {
      margin-bottom: 1rem;
    }

    .work-card__link {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      width: 100%;
      padding: 0.7rem 1rem;
      border: 2px solid var(--color-border);
      border-radius: var(--border-radius-pill);
      background: rgba(255, 255, 255, 0.7);
      color: var(--color-text);
      font-size: 0.9rem;
      font-weight: 800;
      text-decoration: none;
      transition: transform var(--transition-fast), background-color var(--transition-fast);
    }

    .work-card__link:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.95);
      color: var(--color-text);
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .project-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border: 2px solid var(--color-border);
      border-radius: 1.35rem;
      border-radius: 1.5rem;
      background: var(--color-bg-elevated);
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .project-card:hover,
    .work-card:hover,
    .workflow-card:hover,
    .timeline-item:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }

    .project-card__media {
      aspect-ratio: 16 / 10;
      border-bottom: 2px solid var(--color-border);
      background: var(--color-bg-secondary);
      overflow: hidden;
    }

    .project-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .project-card__placeholder {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 100%;
      height: 100%;
      padding: 1rem;
